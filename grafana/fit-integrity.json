          "id": "calculateField",
          "options": {
            "alias": "FIT Headroom Wh",
            "binary": {
              "left": {
                "matcher": {
                  "id": "byName",
                  "options": "Solis PV Generated Wh"
                }
              },
              "operator": "-",
              "right": {
